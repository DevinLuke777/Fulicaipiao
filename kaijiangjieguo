<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>福彩开奖 |Refinement | 喜迎大奖</title>
    <style>
        /* CSS 变量 */
        :root {
            --bg-deep-red: #4a0002; 
            --card-red: #b3000b;    
            --card-red-hover: #cc000e;
            --gold-light: #ffeba1;
            --gold-base: #ffd700;
            --gold-gradient: linear-gradient(135deg, #bf953f 0%, #fcf6ba 25%, #b38728 50%, #fbf5b7 75%, #aa771c 100%);
            --text-cream: #fff3e0; 
            --font-serif: 'Noto Serif SC', 'STZhongsong', 'SimSun', serif;
            --font-sans: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
            /* 强制数字使用最清晰的粗体系统字体 */
            --font-num: Arial, Helvetica, sans-serif; 
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg-deep-red);
            background-image: radial-gradient(circle at 50% 0%, #850009 0%, transparent 70%);
            color: var(--text-cream);
            font-family: var(--font-sans);
            min-height: 100vh;
            padding: 2rem 1.5rem 4rem;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        header {
            width: 100%;
            max-width: 960px;
            text-align: center;
            margin-bottom: 3rem;
            padding-top: 2rem;
            animation: dropDown 1s cubic-bezier(0.2, 0.8, 0.2, 1);
        }

        header::after {
            content: '';
            display: block;
            width: 150px;
            height: 3px;
            background: var(--gold-gradient);
            margin: 1.5rem auto 0;
            border-radius: 2px;
        }

        .main-title {
            font-family: var(--font-serif);
            font-size: 3.5rem;
            font-weight: 900;
            letter-spacing: 4px;
            background: var(--gold-gradient);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 0 4px 15px rgba(255, 215, 0, 0.3);
            margin-bottom: 0.5rem;
        }

        .sub-title {
            font-size: 1.1rem;
            color: var(--gold-light);
            letter-spacing: 2px;
            opacity: 0.9;
        }

        .date-display {
            font-family: var(--font-serif);
            margin-top: 1rem;
            font-size: 1rem;
            color: var(--text-cream);
            background: rgba(0, 0, 0, 0.2);
            display: inline-block;
            padding: 0.4rem 1.5rem;
            border-radius: 30px;
            border: 1px solid rgba(255, 215, 0, 0.2);
        }

        .grid-container {
            width: 100%;
            max-width: 960px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2.5rem;
        }

        .card {
            background-color: var(--card-red);
            border: 1px solid transparent; 
            background-image: linear-gradient(var(--card-red), var(--card-red)), var(--gold-gradient);
            background-origin: border-box;
            background-clip: content-box, border-box;
            border-radius: 12px;
            padding: 2rem;
            position: relative;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5), inset 0 0 20px rgba(0,0,0,0.2);
            opacity: 0;
            transform: scale(0.95);
            /* 居中所有内容的基础设置 */
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        /* 极大缩小四角的金框 */
        .card::before, .card::after {
            content: '';
            position: absolute;
            width: 10px;  /* 更小尺寸 */
            height: 10px; /* 更小尺寸 */
            border: 1px solid var(--gold-base); /* 边框变细 */
            pointer-events: none;
            opacity: 0.8; 
        }
        .card::before {
            top: 6px; left: 6px;
            border-right: none; border-bottom: none;
        }
        .card::after {
            bottom: 6px; right: 6px;
            border-left: none; border-top: none;
        }

        .card:hover {
            background-color: var(--card-red-hover);
            background-image: linear-gradient(var(--card-red-hover), var(--card-red-hover)), var(--gold-gradient);
            transform: scale(1.02) translateY(-5px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6), 0 0 30px rgba(255, 215, 0, 0.2);
            transition: all 0.4s ease;
        }

        /* 居中卡片头部 */
        .card-header {
            width: 100%;
            margin-bottom: 1rem;
            border-bottom: 1px dashed rgba(255, 215, 0, 0.3);
            padding-bottom: 1rem;
        }

        .lottery-name {
            font-family: var(--font-serif);
            font-size: 2.2rem;
            font-weight: bold;
            color: var(--gold-light);
            text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
            margin-bottom: 0.5rem;
        }

        .meta-group {
            /* 居中 meta info */
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .issue-tag {
            background: var(--gold-gradient);
            color: var(--bg-deep-red);
            font-weight: bold;
            font-size: 0.85rem;
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            margin-bottom: 0.4rem;
            box-shadow: 0 2px 5px rgba(0,0,0,0.3);
        }

        .date-info {
            font-size: 0.85rem;
            color: var(--text-cream);
        }

        .date-info.today {
            color: var(--gold-base);
            font-weight: bold;
            text-shadow: 0 0 8px rgba(255, 215, 0, 0.6);
        }

        .rule-info {
            font-size: 0.75rem;
            color: rgba(255, 243, 224, 0.7);
            margin-top: 0.3rem;
        }

        /* 居中摇奖球展示区 */
        .balls-container {
            width: 100%;
            display: flex;
            flex-wrap: wrap;
            justify-content: center; /* 居中球 */
            gap: 0.8rem;
            margin-top: 1.5rem;
        }

        /* 优化球体内数字的清晰度与显眼度 */
        .ball {
            width: 46px;
            height: 46px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: var(--font-num); /* 使用最易读的系统字体 */
            font-size: 1.6rem; /* 极大缩小尺寸后保持大字号，确保显眼 */
            font-weight: 900;   /* 最黑粗体 */
            color: #ffffff;     /* 纯白文字 */
            /* 减弱内部阴影，增加干净度 */
            box-shadow: 
                inset -3px -3px 6px rgba(0,0,0,0.25), 
                inset 3px 3px 6px rgba(255,255,255,0.4),
                0 4px 8px rgba(0,0,0,0.3);
            /* 强化深色文字阴影，使白字极其锐利突出 */
            text-shadow: 0 1px 3px rgba(0, 0, 0, 0.9), 0 0 2px rgba(0,0,0,0.6);
        }

        /* 提升球体高光亮度 */
        .ball.red {
            background: radial-gradient(circle at 30% 30%, #ff8a66, #e60012, #a30000);
            border: 1px solid #ffaa94;
        }

        .ball.blue {
            background: radial-gradient(circle at 30% 30%, #5cb3ff, #0066cc, #003366);
            border: 1px solid #8eccff;
        }

        .skeleton-loader { opacity: 0.5; animation: pulse 1.5s infinite; }
        .skeleton-ball { width: 46px; height: 46px; border-radius: 50%; background: rgba(255,215,0,0.2); }
        .skeleton-text { height: 20px; background: rgba(255,215,0,0.2); margin-bottom: 10px; border-radius: 4px; }

        @keyframes pulse { 0% { opacity: 0.4; } 50% { opacity: 0.8; } 100% { opacity: 0.4; } }
        @keyframes dropDown { from { opacity: 0; transform: translateY(-30px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes popIn { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }

        @media (max-width: 600px) {
            .main-title { font-size: 2.5rem; }
            .grid-container { gap: 1.5rem; }
            .ball { width: 40px; height: 40px; font-size: 1.4rem; }
            .lottery-name { font-size: 1.8rem; }
        }
    </style>
</head>
<body>

    <header>
        <h1 class="main-title">福彩开奖公告</h1>
        <div class="sub-title">迎祥纳福 · 财源广进</div>
        <div class="date-display" id="systemDate">加载中...</div>
    </header>

    <main class="grid-container" id="lotteryBoard">
        <div class="card skeleton-loader">
            <div class="skeleton-text" style="width: 70%; margin: 0 auto;"></div>
            <div class="skeleton-text" style="width: 50%; margin: 10px auto;"></div>
            <div style="margin-top: 30px; display: flex; gap: 10px; justify-content: center;">
                <div class="skeleton-ball"></div><div class="skeleton-ball"></div><div class="skeleton-ball"></div>
            </div>
        </div>
    </main>

    <script>
        const initSysDate = () => {
            const now = new Date();
            const days = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];
            const dateStr = now.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
            document.getElementById('systemDate').innerText = `今日：${dateStr} ${days[now.getDay()]}`;
        };

        const fetchLotteryData = () => {
            return new Promise(resolve => {
                setTimeout(() => {
                    resolve([
                        {
                            id: 'ssq', name: '双色球', issue: '2026038',
                            drawDate: '2026-04-02', rules: '每周二、四、日开奖',
                            reds: ['03', '08', '11', '14', '18', '23'], blues: ['16']
                        },
                        {
                            id: '3d', name: '福彩 3D', issue: '2026085',
                            drawDate: '2026-04-04', rules: '每日开奖',
                            reds: ['8', '0', '5'], blues: []
                        },
                        {
                            id: 'qlc', name: '七乐彩', issue: '2026037',
                            drawDate: '2026-04-03', rules: '每周一、三、五开奖',
                            reds: ['01', '05', '09', '15', '22', '26', '28'], blues: ['12']
                        },
                        {
                            id: 'kl8', name: '快乐 8', issue: '2026085',
                            drawDate: '2026-04-04', rules: '每日开奖',
                            reds: ['02', '05', '13', '18', '22', '29', '34', '35', '41', '44', '52', '58', '60', '63', '67', '71', '75', '77', '79', '80'], blues: []
                        }
                    ]);
                }, 400);
            });
        };

        const createCard = (data, index) => {
            const card = document.createElement('div');
            card.className = 'card';
            card.style.animation = `popIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards`;
            card.style.animationDelay = `${index * 0.1}s`;

            const redHtml = data.reds.map(n => `<div class="ball red">${n}</div>`).join('');
            const blueHtml = data.blues.map(n => `<div class="ball blue">${n}</div>`).join('');

            const todayStr = new Date().toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '-');
            const isToday = data.drawDate === todayStr;
            const dateClass = isToday ? 'date-info today' : 'date-info';
            const dateText = isToday ? `${data.drawDate} (今日开奖)` : data.drawDate;

            card.innerHTML = `
                <div class="card-header">
                    <div class="lottery-name">${data.name}</div>
                    <div class="meta-group">
                        <div class="issue-tag">第 ${data.issue} 期</div>
                        <div class="${dateClass}">开奖日: ${dateText}</div>
                        <div class="rule-info">${data.rules}</div>
                    </div>
                </div>
                <div class="balls-container">
                    ${redHtml}
                    ${blueHtml}
                </div>
            `;
            return card;
        };

        const renderBoard = async () => {
            initSysDate();
            const board = document.getElementById('lotteryBoard');
            const data = await fetchLotteryData();
            
            board.innerHTML = ''; 
            data.forEach((item, index) => {
                board.appendChild(createCard(item, index));
            });
        };

        window.addEventListener('DOMContentLoaded', renderBoard);
    </script>
</body>
</html>
